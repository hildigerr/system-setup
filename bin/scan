#!/bin/sh
OUT=${1:-output}
TMP_DIR="/tmp/scan_$(date +%s)"
PAGE=1
RESULT=0

mkdir -p "$TMP_DIR"

while true; do
  printf "\nCurrent Page: %d\n" "$PAGE"
  printf "Select input: [f]latbed, [a]df, or [q]uit and compile: "
  read -r input

  case "$input" in
    f|flatbed)
      # Single page from flatbed
      scanimage -d 'airscan' \
            --mode 'Color' \
            --resolution 300 \
            --format=tiff > "${TMP_DIR}/page-$(printf "%03d" "$PAGE").tiff"
      RESULT = $?
      ;;

    a|adf)
      # Batch scan from ADF
      scanimage --source 'ADF' \
            --mode 'Color' \
            --resolution 300 \
            --batch="$TMP_DIR/page-%03d.tiff" \
            --batch-start="$PAGE" \
            --format=tiff
      RESULT = $?
      ;;

    q|quit) break ;;
    *) printf "Invalid selection.\n" ;;
  esac

  if [ RESULT -ne 0 ]; then
    printf "Scan failed on page %d. Please check the connection.\n" "$PAGE"
    exit RESULT
  fi

  # Update PAGE count based on how many files are now in TMP_DIR
  PAGE=$(ls -1 "$TMP_DIR"/page-*.tiff | wc -l)
  PAGE=$((PAGE + 1))
done

if [ "$PAGE" -gt 1 ]; then
  tiffcp "${TMP_DIR}/page-"*.tiff "${TMP_DIR}/all_pages.tiff"
  tiff2pdf -o "${OUT}.pdf" "${TMP_DIR}/all_pages.tiff"
  printf "Saved to %s.pdf\n" "${OUT}"
else
  printf "No pages scanned.\n"
fi
